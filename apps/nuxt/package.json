{
  "name": "internship-review-nuxt-app",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "NODE_PATH=./node_modules vitest run",
    "test:unit": "vitest run --project unit",
    "test:nuxt": "NODE_PATH=./node_modules vitest run --project nuxt",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "@tailwindcss/vite": "^4.1.18",
    "nuxt": "^4.3.0",
    "tailwindcss": "^4.1.18",
    "vue": "^3.5.27"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "4.0.0",
    "@types/node": "^25.2.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.8.4",
    "prettier": "^3.8.1",
    "vitest": "^4.1.0"
  }
}
